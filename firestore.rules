rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Gifts — authenticated users can read all
    // Only the owner can update (choose/release) their own choice
    match /gifts/{giftId} {
      allow read: if request.auth != null;

      // Allow choosing a free gift
      allow update: if request.auth != null
        && (
          // Releasing: must be the owner
          (resource.data.chosenBy == request.auth.uid
            && request.resource.data.chosenBy == null)
          ||
          // Choosing: gift must be free
          (resource.data.chosenBy == null
            && request.resource.data.chosenBy == request.auth.uid)
          ||
          // Updating customText on own gift
          (resource.data.chosenBy == request.auth.uid
            && request.resource.data.chosenBy == request.auth.uid
            && request.resource.data.keys().hasOnly(['customText', 'chosenBy', 'chosenByName', 'chosenByPhoto', 'name', 'icon', 'isOther']))
        );

      // Seeding: allow any authenticated user to create gift docs
      // (seed only runs when collection is empty — checked in app logic)
      allow create: if request.auth != null;

      // No deletes by regular users
      allow delete: if false;
    }

    // Messages — authenticated users can read and create
    // Only the specific admin email can delete
    match /messages/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 300;
      allow delete: if request.auth != null
        && request.auth.token.email in [
          'nessacarolsp@gmail.com',
          'adicione_mais_um_email_aqui@gmail.com'
        ];
      allow update: if false;
    }
  }
}
